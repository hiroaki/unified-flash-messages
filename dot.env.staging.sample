# Required in production and staging environments
# SECRET_KEY_BASE is used for encrypting sessions, cookies, and other sensitive data.
# 
# Generate a new secret key using Rails:
#   bin/rails secret
#
# IMPORTANT: 
# - Use a different key for each environment (production, staging)
# - Keep these keys secure and never commit them to version control
# - The key should be 128 hexadecimal characters long
# - Once set, DO NOT change this key as it will invalidate all existing sessions and encrypted data
SECRET_KEY_BASE=abc123def456...

# If you want to use Basic Authentication, set these environment variables.
#BASIC_AUTH_USER=guest
#BASIC_AUTH_PASSWORD=flash-unified

# The following variables are used to set container registry account information.
# - DEPLOY_REGISTRY_SERVER: The URL or hostname of your container registry.
# - DEPLOY_REGISTRY_USERNAME: The username for authenticating to the container registry.
# - DEPLOY_REGISTRY_PASSWORD: The password or access token for the container registry.
DEPLOY_REGISTRY_SERVER=ghcr.io
DEPLOY_REGISTRY_USERNAME=yourname
DEPLOY_REGISTRY_PASSWORD=ghp_Vf7...

# DEPLOY_IMAGE specifies the name of the container image to be built and deployed.
# Example: my-app or your-org/your-app
DEPLOY_IMAGE=your-name/your-app

# List of server hosts to deploy to.
# You can specify multiple hosts separated by commas, but usually one is sufficient.
DEPLOY_SERVERS_WEB_HOSTS="staging.example.com"

# Set SSH configuration information for logging into the deployment host(s).
# For DEPLOY_SSH_KEYS, specify the file path(s) to your SSH private key(s).
# If you have multiple keys, separate them with commas.
DEPLOY_SSH_PORT=2222
DEPLOY_SSH_USER=yourname
DEPLOY_SSH_KEYS="/Users/yourname/.ssh/rsa_id_rsa"

# Host directory to mount into the container for data persistence.
# If not specified, data will not be persisted and will be lost when the container is restarted.
# For demo purposes, leaving this unset is usually fine.
# If you specify a directory, make sure to create it on the host before deploying.
DEPLOY_VOLUMES_STORAGE=/home/yourname/unified-flash-messages-storage

# The deployment host for kamal-proxy.
# This must match the Common Name (CN) of your custom TLS certificate.
DEPLOY_PROXY_HOST=staging.example.com

# The maximum allowed request body size in bytes.
# Requests exceeding this size will be blocked by kamal-proxy.
# For demonstration purposes, set a small value.
DEPLOY_PROXY_BUFFERING_MAX_REQUEST_BODY=1024

# Port numbers used by the Thruster and Rails applications.
# Change these values if there are conflicting services on the deployment host.
DEPLOY_THRUSTER_HTTP_PORT=3001
DEPLOY_THRUSTER_TARGET_PORT=3000

# Custom TLS certificate (also known as SSL/TLS certificate).
# Paste the entire contents of your PEM-formatted certificate file here.
DEPLOY_CERTIFICATE_PEM="-----BEGIN CERTIFICATE-----
...
...
-----END CERTIFICATE-----
"

# Custom TLS private key.
# Paste the entire contents of your PEM-formatted private key file here.
DEPLOY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
...
...
-----END PRIVATE KEY-----
"
